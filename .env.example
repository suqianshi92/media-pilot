# Media Pilot Docker minimal configuration
#
# Copy to .env, fill API keys, then run: docker compose up -d
# Prowlarr and qB credentials are generated automatically by media-pilot-init.

# Published application image. Replace this with the official Docker Hub image
# name once you deploy from a release instead of building from source.
MEDIA_PILOT_IMAGE=suqianshi/media-pilot:latest

# ---- Host paths mounted into fixed container paths ----
MEDIA_PILOT_DOWNLOADS_DIR=./data/downloads
MEDIA_PILOT_WATCH_DIR=./data/watch
MEDIA_PILOT_WORKSPACE_DIR=./data/workspace
MEDIA_PILOT_MOVIES_DIR=./data/library/movies
MEDIA_PILOT_SHOWS_DIR=./data/library/shows
MEDIA_PILOT_DATABASE_DIR=./data/db
MEDIA_PILOT_ADULT_MOVIES_DIR=./data/library/adult
MEDIA_PILOT_TRASH_DIR=./data/trash
POSTGRES_DATA_DIR=./data/postgres

# Third-party service config directories.
PROWLARR_CONFIG_DIR=./data/prowlarr/config
QBITTORRENT_CONFIG_DIR=./data/qbittorrent/config

# ---- Required APIs ----
MEDIA_PILOT_LLM_API_KEY=sk-your-api-key
MEDIA_PILOT_LLM_BASE_URL=https://api.openai.com/v1
MEDIA_PILOT_LLM_MODEL=gpt-4o-mini
MEDIA_PILOT_TMDB_API_KEY=your-tmdb-api-key

# Optional TPDB /jav metadata. Leave empty unless needed.
MEDIA_PILOT_TPDB_API_KEY=

# ---- Generated by Docker init. Leave empty unless taking over manually. ----
MEDIA_PILOT_PROWLARR_API_KEY=
MEDIA_PILOT_QBITTORRENT_USERNAME=
MEDIA_PILOT_QBITTORRENT_PASSWORD=
MEDIA_PILOT_BOOTSTRAP_FORCE=

# Internal service URLs. Keep defaults unless using external services.
MEDIA_PILOT_PROWLARR_URL=http://media-pilot-prowlarr:9696
MEDIA_PILOT_QBITTORRENT_URL=http://media-pilot-qbittorrent:8080

# PostgreSQL is the recommended production database. Keep this service-name URL
# unless you run PostgreSQL outside this compose project.
POSTGRES_DB=media_pilot
POSTGRES_USER=media_pilot
POSTGRES_PASSWORD=media_pilot
MEDIA_PILOT_DATABASE_URL=postgresql+psycopg://media_pilot:media_pilot@media-pilot-postgres:5432/media_pilot

# ---- Host ports / runtime identity ----
MEDIA_PILOT_PORT=8000
PROWLARR_PORT=9696
QBITTORRENT_PORT=8088
PUID=1000
PGID=1000
TZ=Asia/Shanghai

# Optional FlareSolverr service is commented out in docker-compose.yml.
# FLARESOLVERR_PORT=8191
# FLARESOLVERR_LOG_LEVEL=info

# Advanced overrides: see docs/deployment.md.
